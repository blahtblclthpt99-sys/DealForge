# Production — copy to .env on your host (Vercel: add in dashboard)
# Vercel cannot use SQLite; use Neon/Supabase Postgres and run db:setup once.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/dealforge?sslmode=require"
AUTH_SECRET="generate-with-openssl-rand-hex-32"
ADMIN_EMAIL="admin@dealforge.com"
ADMIN_PASSWORD="ChangeMeAdmin123!"
AMAZON_ASSOCIATE_TAG="titanfieldos-20"
AMAZON_PARTNER_TAG="titanfieldos-20"
NEXT_PUBLIC_APP_URL="https://your-domain.com"
NEXT_PUBLIC_APP_NAME="DealForge"
