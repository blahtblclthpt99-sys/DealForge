# Production — set these in Vercel → Settings → Environment Variables
# Vercel cannot use SQLite. Use free Neon Postgres: https://neon.tech

DATABASE_URL="postgresql://USER:PASSWORD@HOST/dealforge?sslmode=require"

# After setting DATABASE_URL, seed once from your PC:
#   $env:DATABASE_URL="postgresql://..."
#   npx prisma db push --schema=prisma/schema.postgres.prisma
#   npx tsx prisma/seed.ts

AUTH_SECRET="generate-a-long-random-string"
ADMIN_EMAIL="admin@dealforge.com"
ADMIN_PASSWORD="ChangeMeAdmin123!"

AMAZON_ASSOCIATE_TAG="titanfieldos-20"
AMAZON_PARTNER_TAG="titanfieldos-20"

NEXT_PUBLIC_APP_URL="https://deal-forge-alpha.vercel.app"
NEXT_PUBLIC_APP_NAME="DealForge"
