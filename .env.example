# Amazon Associates (DealForge)
AMAZON_ASSOCIATE_TAG="titanfieldos-20"
AMAZON_PARTNER_TAG="titanfieldos-20"
AMAZON_ACCESS_KEY=""
AMAZON_SECRET_KEY=""
AMAZON_HOST="webservices.amazon.com"
AMAZON_REGION="us-east-1"

# eBay Partner Network
