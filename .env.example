EBAY_AFFILIATE_TRACKING_ID=""

# AliExpress Affiliate / Portals
ALIEXPRESS_AFF_SHORT_KEY=""
ALIEXPRESS_PUBLISHER_ID=""

# Optional Redis (falls back to in-memory cache)
